# ==========================================
# ⚙️ SERVIDOR BASE Y SEGURIDAD
# ==========================================
PORT=3007
NODE_ENV=development

# ==========================================
# 🗄️ BASE DE DATOS ANALÍTICA (POSTGRESQL + POSTGIS)
# ==========================================
DB_HOST=db-fococero
DB_PORT=5432
DB_HOST_LOCAL=localhost
DB_PORT_LOCAL=5433
DB_USER=fococero_admin
DB_PASSWORD=foco0-1234
DB_NAME=analitica_db

# ==========================================
# 🚀 CACHÉ EN MEMORIA (REDIS)
# Para reportes pre-calculados (Mapas de calor)
# ==========================================
REDIS_HOST=redis-fococero
REDIS_PORT=6379
REDIS_HOST_LOCAL=localhost
REDIS_PORT_LOCAL=6379

# ==========================================
# 📬 BUS DE EVENTOS (RABBITMQ)
# Para ingestar eventos en tiempo real sin saturar HTTP
# ==========================================
RABBITMQ_URL=amqp://admin:foco0-1234@rabbitmq:5672
RABBITMQ_URL_LOCAL=amqp://admin:foco0-1234@localhost:5672

EUREKA_HOST=eureka-server
EUREKA_CLIENT_REGISTERWITHEUREKA=true
EUREKA_CLIENT_FETCHREGISTRY=true
EUREKA_INSTANCE_PORT=3007
INTERNAL_SECRET_TOKEN=0b9d32feb3b6f0f786529ae12f90d2d31d1132566053f89626774ab53fc69c23
API_GATEWAY_URL=http://api-gateway:3000

