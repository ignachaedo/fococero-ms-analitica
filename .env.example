# ==========================================
# 📊 MS-ANALITICA - Variables de Entorno
# ==========================================
# Copia este archivo a .env y personaliza

# Puerto del servicio
PORT=3007

# Node environment
NODE_ENV=development

# Base de datos PostgreSQL (Docker)
DB_USER=fococero_admin
DB_PASSWORD=change-me-db-password
DB_HOST=db-fococero
DB_PORT=5432
DB_NAME=analitica_db

# Base de datos PostgreSQL (Local)
DB_HOST_LOCAL=localhost
DB_PORT_LOCAL=5433

# Redis (Docker)
REDIS_HOST=redis-fococero
REDIS_PORT=6379

# Redis (Local)
REDIS_HOST_LOCAL=localhost
REDIS_PORT_LOCAL=6379

# RabbitMQ (Docker)
RABBITMQ_URL=amqp://admin:change-me-password@rabbitmq-fococero:5672

# RabbitMQ (Local)
RABBITMQ_URL_LOCAL=amqp://guest:guest@localhost:5672

# Eureka Service Discovery
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_CLIENT_REGISTERWITHEUREKA=true
EUREKA_CLIENT_FETCHREGISTRY=true
EUREKA_INSTANCE_PORT=3007

# Seguridad interna
INTERNAL_SECRET_TOKEN=change-me-internal-token
API_GATEWAY_URL=http://api-gateway:3000
